# ═══════════════════════════════════════════
# hermes-messaging-tts-skill — 环境变量配置
# ═══════════════════════════════════════════
# 复制此文件为 .env 并填入真实值
#   cp .env.example .env
#
# 优先级: 环境变量 > .env > Hermes config.yaml
#
# ═══════════════════════════════════════════

# ─── MiMo API Key（必填 — MiMo TTS / VoiceClone 都需要）───
# 从 https://platform.xiaomimimo.com 获取
MIMO_API_KEY=your_mimo_api_key_here

# ─── MiMo API Base URL（一般不用改）───
# 国内节点
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
# 国际节点（备用）
# MIMO_API_BASE=https://token-plan.xiaomimimo.com/v1

# ─── 默认声线（可选，默认 茉莉）───
# MiMo TTS: 茉莉, 冰糖, 苏打, 白桦, Mia, Chloe, Milo, Dean
# Edge TTS: xiaoxiao, yunxi, yunyang
DEFAULT_VOICE=茉莉

# ─── VoiceClone 参考音频路径（可选，scripts/prepare-voice-ref.sh 会设置）───
REFERENCE_AUDIO=./references/voiceref-my-voice.wav

# ─── 临时目录（可选，默认 /tmp/hermes-voice）───
TEMP_DIR=/tmp/hermes-voice
